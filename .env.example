# ─── OpenAI ─────────────────────────────────────────────────────────────────
# Required for embeddings (text-embedding-3-small) and triage LLM (gpt-4o).
OPENAI_API_KEY=sk-...

# ─── LangSmith ───────────────────────────────────────────────────────────────
# Required for evaluation (evaluate.py) and optional for tracing triage runs.
# Sign up at https://smith.langchain.com — free tier is sufficient for this repo.
LANGCHAIN_API_KEY=ls__...

# LangSmith project name. All traces and eval experiments will be grouped here.
LANGCHAIN_PROJECT=rag-merchant-triage

# Set to "true" to enable automatic LangSmith tracing for all LangChain calls.
# Set to "false" to disable tracing (e.g., in local dev without LangSmith setup).
LANGCHAIN_TRACING_V2=true

# ─── Optional ────────────────────────────────────────────────────────────────
# Override the default ChromaDB persistence directory.
# CHROMA_PERSIST_DIR=.chroma_db

# Override the OpenAI embedding model (default: text-embedding-3-small).
# Use text-embedding-3-large for higher accuracy at ~6x cost.
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Override the triage LLM model (default: gpt-4o).
# OPENAI_TRIAGE_MODEL=gpt-4o
